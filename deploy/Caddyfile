# Caddy reverse proxy on a CUSTOM HTTPS port (avoids 80/443 if they are taken).
# Uses Caddy's local CA (`tls internal`) so no port 80 / ACME is required — HTTPS
# works on any port, enabling the camera (getUserMedia). Browsers show a one-time
# "untrusted certificate" warning to accept. DOMAIN / CADDY_HTTPS_PORT come from .env.
{
	email {$ACME_EMAIL}
}

{$DOMAIN}:{$CADDY_HTTPS_PORT} {
	tls internal
	encode zstd gzip
	request_body {
		max_size 8MB
	}
	# Security headers. No HSTS here: with a self-signed (internal) cert, HSTS would make
	# the untrusted-cert warning impossible to bypass and lock users out.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	# the frontend nginx (which itself proxies /api -> backend) on the internal network
	reverse_proxy frontend:80
}
