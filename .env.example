# Copy to .env and adjust before deploying: cp .env.example .env

# =====================  PORTS  =====================
# The ONLY port published on the host is the web app. Pick any free port — no need
# to stop other services. Put it behind a TLS reverse proxy (80/443) in production.
WEB_PORT=8973
# Everything else (backend 8390, PostgreSQL 5432, MinIO S3 9000 + console 9001) lives
# only on the internal Docker network and is NOT published — zero host port conflicts.
# To expose the DB or MinIO console temporarily for admin, uncomment their `ports:`
# lines in docker-compose.yml and set a free port here:
# DB_PORT=55432
# MINIO_CONSOLE_PORT=9011

# =====================  PostgreSQL  =====================
POSTGRES_DB=promote
POSTGRES_USER=promote
POSTGRES_PASSWORD=change-this-db-password

# =====================  Backend  =====================
# Must be at least 32 bytes. Generate one with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes

# Real administrator account (created on first start with an empty database).
ADMIN_EMAIL=admin.promote@afrilandfirstbank.com
ADMIN_PASSWORD=change-this-strong-admin-password
ADMIN_NAME=Administrateur Promote
# Set to false in production to skip the demo relationship-officer (awa.fall / promote).
SEED_TEST_AGENT=true
# Print point account (PRINT_AGENT) — created on first start (and on existing deployments).
PRINT_EMAIL=imprimeur.promote@afrilandfirstbank.com
PRINT_PASSWORD=change-this-strong-print-password
PRINT_NAME=Point d'impression
# Payment gateway: simulated | trustpayway
APP_PAYMENT_PROVIDER=simulated
# --- TrustPayWay aggregator (only used when APP_PAYMENT_PROVIDER=trustpayway) ---
TRUSTPAYWAY_BASE_URL=
TRUSTPAYWAY_SECRET_KEY=
TRUSTPAYWAY_APPLICATION_ID=
TRUSTPAYWAY_NOTIF_URL=https://your-public-host/api/payment/webhook/trustpayway
TRUSTPAYWAY_WEBHOOK_SECRET=
# Allowed CORS origin(s) for the API (comma-separated). Use your public URL in production.
APP_CORS_ALLOWED_ORIGINS=http://localhost:8973

# =====================  HTTPS (with docker-compose.tls.yml)  =====================
# Hostname served over HTTPS. No domain? Use sslip.io with your IP, e.g.:
#   DOMAIN=62.169.26.178.sslip.io
DOMAIN=62.169.26.178.sslip.io
ACME_EMAIL=admin@example.com
# Caddy serves HTTPS on this CUSTOM port (avoids 80/443 if they are already used).
CADDY_HTTPS_PORT=8443
# Behind Caddy, keep the web app off the public interface (Caddy reaches it internally):
#   WEB_PORT=127.0.0.1:8973
# Set the CORS origin to your HTTPS URL (include the port):
#   APP_CORS_ALLOWED_ORIGINS=https://62.169.26.178.sslip.io:8443

# =====================  Object storage (MinIO / S3)  =====================
# KYC selfie images are stored here; only references live in the database.
MINIO_ROOT_USER=promote
MINIO_ROOT_PASSWORD=change-this-minio-secret
S3_BUCKET=kyc-selfies
