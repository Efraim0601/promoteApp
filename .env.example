# Copy to .env and adjust before deploying: cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=promote
POSTGRES_USER=promote
POSTGRES_PASSWORD=change-this-db-password

# --- Backend ---
# IMPORTANT: must be at least 32 bytes. Generate one with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-bytes

# Payment gateway provider: simulated | maviance | trustpayway (only "simulated" is active for now)
APP_PAYMENT_PROVIDER=simulated

# Allowed CORS origin(s) for the API (comma-separated). Use your public URL in production.
APP_CORS_ALLOWED_ORIGINS=http://localhost

# --- Frontend ---
# Host port the web app is published on (map to 80/443 behind a TLS reverse proxy in prod)
HTTP_PORT=80
